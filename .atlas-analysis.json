  "keyFeatures": [
    "Ed25519 key generation and signing with chain-ID binding",
    "MessagePack codec with rmp-serde-compatible minimal-int encoding",
    "Timestamp-nonce allocation with replay-window protection",
    "Gateway and CometBFT submission with fire-and-forget or commit modes",
    "Full query surface: orderbook, account, markets, ticker, history, ADL queue",
    "WebSocket block subscription for real-time exchange events",
    "Python bindings via PyO3 over shared Rust core",
    "Agent wallet delegation for programmatic/bot trading",
    "Atomic multi-leg basket orders (fill-or-kill)",
    "Discriminated-union Action type covering all 20+ exchange operations"
  ],
  "publicApiSurface": [
    "ExchangeClient",
    "ExchangeClientOptions",
    "generateKeypair()",
    "pubkeyToOwner()",
    "ownerToHex()",
    "hexToBytes()",
    "bytesToHex()",
    "signAndEncode()",
    "decodeTx()",
    "fetchChainId()",
    "chainIdFromString()",
    "decodeExecError()",
    "execErrorName()",
    "Action (discriminated union)",
    "Side (enum: Buy | Sell)",
    "TimeInForce (enum: Gtc | Ioc | Fok)",
    "ActionType (wire byte constants)",
    "TxResult",
    "ExchangeEvent",
    "PlaceOrder, CancelOrder, CancelAllOrders, CancelReplaceOrder, AmendOrder",
    "MarketOrder, ClosePosition, AtomicBasketOrder",
    "ApproveAgent, RevokeAgent",
    "WithdrawRequest, ConfirmDeposit",
    "AccountInfo, PositionInfo, Orderbook, OpenOrder, Ticker, MarketConfig"
  ]
}
